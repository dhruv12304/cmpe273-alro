# Copy this file to .env and fill in ANTHROPIC_API_KEY before running `make up`.

# ---- Required ---------------------------------------------------------------

# Anthropic API key — used by the Agent Service for Claude reasoning.
ANTHROPIC_API_KEY=

# ---- Grid & training (optional — defaults shown) ----------------------------

# Grid dimension N. Creates an N×N node graph (warehouses left, destinations right).
GRID_SIZE=5

# Default episode count for the /train endpoint.
TRAINING_EPISODES=500

# ---- Q-learning hyperparameters (optional) ----------------------------------

# Initial exploration rate for epsilon-greedy action selection.
EPSILON_START=1.0

# Multiplicative decay applied to epsilon after each training episode.
EPSILON_DECAY=0.995

# Epsilon floor — exploration never drops below this value.
EPSILON_MIN=0.05

# Q-learning rate (alpha).
ALPHA=0.1

# Discount factor for future rewards (gamma).
GAMMA=0.95

# ---- Agent Service behaviour (optional) -------------------------------------

# Seconds before a cached inventory snapshot is considered stale.
CACHE_TTL_SECONDS=60

# Q-value spread below this threshold triggers a Claude reasoning call.
CLAUDE_CONFIDENCE_THRESHOLD=0.10

# HTTP timeout in seconds for Anthropic API calls.
CLAUDE_TIMEOUT_SECONDS=3

# File path for Q-table persistence inside the agent container.
# Backed by the qtable-data Docker volume — do not change unless remounting.
QTABLE_PATH=/data/qtable.npy
